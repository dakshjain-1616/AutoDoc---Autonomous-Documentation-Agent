# AutoDoc (NEO) Environment Configuration
# Copy this file to .env and fill in your actual values

# Hugging Face API Token
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your_huggingface_api_token_here

# HyperNova Model ID (optional, defaults to HyperNova-60B-2602)
HYPERNOVA_MODEL_ID=HyperNova-60B-2602

# Optional: Confidence threshold for documentation generation (0.0-1.0)
# Default: 0.8
# CONFIDENCE_THRESHOLD=0.8

# Optional: Output directory for reports
# OUTPUT_DIR=./reports
